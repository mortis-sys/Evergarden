---
import "../styles/global.css";
import projects from "../data/projects.json";
import talks from "../data/talks.json";
import animeList from "../data/anime.json";
import gamingList from "../data/gaming.json";
const allData = { projects, talks, anime: animeList, gaming: gamingList };

const photoModules = import.meta.glob(['../photos/*.{jpg,png,jpeg,webp}', '../photos/精选/*.{jpg,png,jpeg,webp}'], { eager: true, import: 'default' });
const photoFilenames = Object.keys(photoModules)
  .sort((a, b) => a.localeCompare(b))
  .map((path) => path.split('/').pop());
const photoFilenamesJson = JSON.stringify(photoFilenames);
---

<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>内容管理 · Evergarden</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✏️</text></svg>">
  </head>
  <body class="min-h-screen bg-gray-50">
    <div id="app" class="mx-auto flex max-w-6xl gap-6 p-6">
      <!-- 侧边栏 -->
      <aside class="w-56 shrink-0">
        <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <h1 class="mb-4 px-2 text-lg font-bold text-gray-800">内容管理</h1>
          <nav class="space-y-1" id="section-tabs">
            {["projects", "talks", "anime", "gaming"].map((key) => (
              <button
                class={`tab-btn w-full rounded-xl px-3 py-2 text-left text-sm font-medium transition ${key === "projects" ? "bg-violet-100 text-violet-700" : "text-gray-500 hover:bg-gray-100"}`}
                data-section={key}
              >{({ projects: "项目", talks: "杂谈", anime: "动漫", gaming: "游戏交流" })[key]}</button>
            ))}
          </nav>
          <hr class="my-4 border-gray-100" />
          <button id="export-btn" class="w-full rounded-xl bg-violet-600 px-3 py-2 text-sm font-medium text-white transition hover:bg-violet-700 mb-2">导出 JSON</button>
          <button id="github-btn" class="w-full rounded-xl border border-gray-300 px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100">推送到 GitHub</button>
        </div>
      </aside>

      <!-- 主内容 -->
      <main class="flex-1">
        <!-- GitHub Token 输入 -->
        <div id="github-config" class="mb-4 hidden rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
          <label class="block text-sm font-medium text-gray-600 mb-1">GitHub Token</label>
          <div class="flex gap-2">
            <input id="github-token" type="password" placeholder="ghp_..." class="flex-1 rounded-xl border border-gray-200 px-3 py-2 text-sm outline-none focus:border-violet-400" />
            <input id="github-repo" type="text" placeholder="owner/repo" value="mortis-sys/personal-site" class="w-48 rounded-xl border border-gray-200 px-3 py-2 text-sm outline-none focus:border-violet-400" />
          </div>
          <p class="mt-1 text-xs text-gray-400">Token 仅存储在浏览器本地，不会上传到其他服务器。</p>
        </div>

        <div id="section-content" class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <!-- 由 JS 动态渲染 -->
        </div>
      </main>
    </div>

    <script>
      const allData = { projects: [], talks: [], anime: [], gaming: [] };
      try { Object.assign(allData, JSON.parse(document.currentScript?.previousElementSibling?.textContent || '{}')); } catch(e) {}

      // 实际数据从模板嵌入
      const dataScript = document.getElementById('initial-data');
    </script>

    <template id="initial-data" set:html={JSON.stringify(allData)}></template>
    <template id="photo-filenames" set:html={photoFilenamesJson}></template>
    <script>
      // ====== 数据层 ======
      let data = {};
      try {
        data = JSON.parse(document.getElementById('initial-data')?.innerHTML || '{}');
      } catch(e) { data = { projects: [], talks: [], anime: [], gaming: [] }; }

      let currentSection = 'projects';
      const sectionLabels = { projects: '项目', talks: '杂谈', anime: '动漫', gaming: '游戏交流' };

      // ====== 渲染 ======
      function render() {
        const items = data[currentSection] || [];
        const label = sectionLabels[currentSection];
        const container = document.getElementById('section-content');

        let html = '<div class="flex items-center justify-between mb-6">';
        html += '<h2 class="text-2xl font-bold text-gray-800">' + label + '</h2>';
        html += '<button onclick="addItem()" class="rounded-xl bg-violet-600 px-4 py-2 text-sm font-medium text-white hover:bg-violet-700 transition">+ 新增</button>';
        html += '</div>';

        if (items.length === 0) {
          html += '<p class="text-gray-400 text-center py-12">暂无内容，点击"+ 新增"添加</p>';
        } else {
          // 表格头
          html += '<div class="space-y-3">';
          items.forEach(function(item, idx) {
            html += '<div class="rounded-xl border border-gray-100 bg-gray-50 p-4">';
            html += '<div class="flex items-start justify-between gap-4">';
            html += '<div class="flex-1 min-w-0">';

            // 标题
            const titleField = currentSection === 'anime' ? 'title' : 'title';
            html += '<input class="item-title w-full rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium outline-none focus:border-violet-400 mb-2" value="' + esc(item.title || '') + '" data-idx="' + idx + '" />';

            // 各字段
            const fields = getFields(currentSection);
            fields.forEach(function(f) {
              if (f === 'title' || f === 'content') return;
              const val = item[f] || '';
              html += '<div class="mb-1.5 flex items-center gap-2">';
              html += '<span class="w-16 text-xs text-gray-400 shrink-0">' + f + '</span>';
              if (f === 'images') {
                const selected = Array.isArray(item.images) ? item.images : (item.image ? [item.image] : []);
                html += '<select multiple class="flex-1 rounded-lg border border-gray-200 bg-white px-2 py-1 text-xs outline-none focus:border-violet-400 item-field" data-idx="' + idx + '" data-field="images" style="min-height:90px">';
                photoFilenames.forEach(function(pf) {
                  html += '<option value="' + esc(pf) + '"' + (selected.indexOf(pf) !== -1 ? ' selected' : '') + '>' + esc(pf) + '</option>';
                });
                html += '</select>';
                html += '<span class="text-[10px] text-gray-400 mt-0.5 block">按住 Ctrl 多选，第一张为封面</span>';
              } else {
                html += '<input class="flex-1 rounded-lg border border-gray-200 bg-white px-2 py-1 text-xs outline-none focus:border-violet-400 item-field" value="' + esc(val) + '" data-idx="' + idx + '" data-field="' + f + '" />';
              }
              html += '</div>';
            });

            // 内容（文本域）
            if (item.content !== undefined) {
              html += '<div class="mt-1.5">';
              html += '<span class="text-xs text-gray-400">正文</span>';
              html += '<textarea rows="4" class="item-content mt-1 w-full rounded-lg border border-gray-200 bg-white px-2 py-1 text-xs outline-none focus:border-violet-400 font-mono" data-idx="' + idx + '">' + esc(item.content || '') + '</textarea>';
              html += '</div>';
            }

            // 动漫描述
            if (item.description !== undefined && item.content === undefined) {
              html += '<div class="mt-1.5">';
              html += '<span class="text-xs text-gray-400">描述</span>';
              html += '<textarea rows="2" class="item-field mt-1 w-full rounded-lg border border-gray-200 bg-white px-2 py-1 text-xs outline-none focus:border-violet-400" data-idx="' + idx + '" data-field="description">' + esc(item.description || '') + '</textarea>';
              html += '</div>';
            }

            html += '</div>'; // flex-1

            // 删除按钮
            html += '<button onclick="deleteItem(' + idx + ')" class="shrink-0 rounded-lg px-3 py-1 text-xs text-red-400 hover:bg-red-50 hover:text-red-600 transition">删除</button>';
            html += '</div>'; // flex
            html += '</div>'; // card
          });
          html += '</div>';
        }

        container.innerHTML = html;
      }

      function getFields(section) {
        const map = {
          projects: ['slug', 'emoji', 'images', 'tag', 'status', 'description'],
          talks: ['slug', 'emoji', 'images', 'tag', 'date'],
          anime: ['slug', 'emoji', 'englishName'],
          gaming: ['slug', 'emoji'],
        };
        return map[section] || [];
      }

      // 从模板中读取可用图片列表
      const photoFilenames = JSON.parse(document.getElementById('photo-filenames')?.innerHTML || '[]');

      function esc(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      // ====== 操作 ======
      window.addItem = function() {
        const template = {
          projects: { slug: '', title: '新项目', emoji: '🎮', images: [], tag: '新标签', status: '', description: '', content: '' },
          talks: { slug: '', title: '新杂谈', emoji: '📝', images: [], tag: '生活', date: '', content: '' },
          anime: { slug: '', title: '新动漫', emoji: '🌸', englishName: '', description: '' },
          gaming: { slug: '', title: '新模块', emoji: '🎮', content: '' },
        };
        data[currentSection].push(template[currentSection]);
        render();
      };

      window.deleteItem = function(idx) {
        if (!confirm('确定删除这条内容吗？')) return;
        data[currentSection].splice(idx, 1);
        render();
      };

      // 保存编辑（实时更新 data）
      document.addEventListener('input', function(e) {
        const el = e.target;
        const idx = parseInt(el.dataset.idx);
        if (isNaN(idx) || idx >= (data[currentSection] || []).length) return;

        if (el.classList.contains('item-title')) {
          data[currentSection][idx].title = el.value;
          // auto-generate slug
          if (data[currentSection][idx].slug === '' || !data[currentSection][idx]._slugEdited) {
            data[currentSection][idx].slug = el.value
              .replace(/[《》·！…，。、\s]+/g, '-')
              .replace(/[^a-zA-Z0-9一-鿿-]/g, '')
              .replace(/^-+|-+$/g, '')
              .toLowerCase() || 'untitled';
            // 直接更新 slug 输入框，不重绘整个页面
            const slugInput = document.querySelector('.item-field[data-idx="' + idx + '"][data-field="slug"]');
            if (slugInput) slugInput.value = data[currentSection][idx].slug;
          }
        } else if (el.classList.contains('item-content')) {
          data[currentSection][idx].content = el.value;
        } else if (el.classList.contains('item-field')) {
          const field = el.dataset.field;
          if (field === 'images' && el.tagName === 'SELECT') {
            data[currentSection][idx].images = Array.from(el.selectedOptions).map(function(o) { return o.value; });
          } else {
            data[currentSection][idx][field] = el.value;
          }
          if (field === 'slug') data[currentSection][idx]._slugEdited = true;
        }
      });

      // 多选下拉变更监听（change 事件比 input 更可靠）
      document.addEventListener('change', function(e) {
        const el = e.target;
        if (!el.classList.contains('item-field') || el.dataset.field !== 'images') return;
        const idx = parseInt(el.dataset.idx);
        if (isNaN(idx) || idx >= (data[currentSection] || []).length) return;
        data[currentSection][idx].images = Array.from(el.selectedOptions).map(function(o) { return o.value; });
      });

      // ====== 选项卡切换 ======
      document.getElementById('section-tabs').addEventListener('click', function(e) {
        const btn = e.target.closest('.tab-btn');
        if (!btn) return;
        currentSection = btn.dataset.section;
        this.querySelectorAll('.tab-btn').forEach(function(b) {
          const isActive = b === btn;
          b.className = 'tab-btn w-full rounded-xl px-3 py-2 text-left text-sm font-medium transition ' +
            (isActive ? 'bg-violet-100 text-violet-700' : 'text-gray-500 hover:bg-gray-100');
        });
        render();
      });

      // ====== 导出 JSON ======
      document.getElementById('export-btn').addEventListener('click', function() {
        const sections = ['projects', 'talks', 'anime', 'gaming'];
        const fileNames = { projects: 'projects.json', talks: 'talks.json', anime: 'anime.json', gaming: 'gaming.json' };

        sections.forEach(function(key) {
          // Clean helper fields before export
          const clean = data[key].map(function(item) {
            const o = Object.assign({}, item);
            delete o._slugEdited;
            delete o.image; // 旧单图字段
            return o;
          });
          const blob = new Blob([JSON.stringify(clean, null, 2)], { type: 'application/json' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = fileNames[key];
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        });
      });

      // ====== GitHub 推送 ======
      document.getElementById('github-btn').addEventListener('click', function() {
        const config = document.getElementById('github-config');
        if (config.classList.contains('hidden')) {
          config.classList.remove('hidden');
          return;
        }

        const token = document.getElementById('github-token').value.trim();
        const repo = document.getElementById('github-repo').value.trim();
        if (!token || !repo) { alert('请填写 GitHub Token 和仓库地址'); return; }

        const sections = ['projects', 'talks', 'anime', 'gaming'];
        const paths = { projects: 'src/data/projects.json', talks: 'src/data/talks.json', anime: 'src/data/anime.json', gaming: 'src/data/gaming.json' };

        (async function() {
          for (const key of sections) {
            const clean = data[key].map(function(item) {
              const o = Object.assign({}, item);
              delete o._slugEdited;
              delete o.image;
              return o;
            });
            const content = btoa(unescape(encodeURIComponent(JSON.stringify(clean, null, 2))));

            // 获取当前文件 SHA（用于更新而非新建）
            let sha = '';
            try {
              const resp = await fetch('https://api.github.com/repos/' + repo + '/contents/' + paths[key], {
                headers: { Authorization: 'Bearer ' + token }
              });
              const existing = await resp.json();
              if (existing.sha) sha = existing.sha;
            } catch(e) {}

            const body = {
              message: '更新 ' + paths[key] + '（通过后台管理）',
              content: content,
              branch: 'main',
            };
            if (sha) body.sha = sha;

            const resp = await fetch('https://api.github.com/repos/' + repo + '/contents/' + paths[key], {
              method: 'PUT',
              headers: {
                Authorization: 'Bearer ' + token,
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(body),
            });

            if (!resp.ok) {
              const err = await resp.json();
              throw new Error(paths[key] + ': ' + (err.message || resp.status));
            }
          }

          alert('全部文件已推送到 GitHub！\nCloudflare Pages 将自动重新部署。');
        })().catch(function(err) {
          alert('推送失败：' + err.message);
        });
      });

      // ====== 初始化 ======
      render();
    </script>
  </body>
</html>
