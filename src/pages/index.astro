                    </a>
                    <a href="mailto:wuzimi@evergarden.dev" class="flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition hover:bg-gray-200/60 hover:text-gray-700" title="邮箱">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- 电子钟 配色方案二：落日余晖 -->
            <div class="rounded-3xl border border-amber-200/50 bg-gradient-to-br from-amber-50/90 via-rose-50/90 to-orange-50/90 p-5 sm:p-6 md:p-7 shadow-sm flex flex-col items-center justify-center text-center relative overflow-hidden min-h-[180px] sm:min-h-[200px] md:min-h-[220px]">
              <!-- 装饰：落日柔光盘 -->
              <div class="absolute -top-10 -right-10 w-32 sm:w-40 h-32 sm:h-40 rounded-full bg-gradient-to-br from-amber-200/20 via-rose-200/15 to-transparent blur-xl"></div>
              <!-- 装饰元素 -->
              <div class="absolute -top-5 -right-5 w-14 sm:w-18 h-14 sm:h-18 rounded-full border border-amber-200/25"></div>
              <div class="absolute -bottom-3 -left-3 w-10 sm:w-12 h-10 sm:h-12 rounded-full border border-rose-200/25"></div>
              <div class="absolute top-4 sm:top-5 right-5 sm:right-7 flex gap-1.5">
                <span class="w-1 h-1 sm:w-1.5 sm:h-1.5 rounded-full bg-amber-300/50"></span>
                <span class="w-1 h-1 sm:w-1.5 sm:h-1.5 rounded-full bg-rose-300/50"></span>
                <span class="w-1 h-1 sm:w-1.5 sm:h-1.5 rounded-full bg-amber-300/50"></span>
              </div>
              <div class="absolute bottom-6 sm:bottom-8 left-4 sm:left-5 w-1.5 sm:w-2 h-1.5 sm:h-2 rotate-45 bg-rose-300/40"></div>

              <!-- 时间 -->
              <div class="flex items-baseline gap-0.5 sm:gap-1 relative z-10" style="font-size: clamp(2rem, 5.5vw, 4rem);">
                <span id="clock-hour" class="font-bold tabular-nums bg-gradient-to-br from-amber-600 via-rose-500 to-orange-500 bg-clip-text text-transparent" style="font-size: inherit">00</span>
                <span id="clock-colon" class="font-bold text-rose-400 mx-0.5 animate-pulse" style="font-size: 0.65em">:</span>
                <span id="clock-min" class="font-bold tabular-nums bg-gradient-to-br from-amber-600 via-rose-500 to-orange-500 bg-clip-text text-transparent" style="font-size: inherit">00</span>
                <span id="clock-sec" class="font-light tabular-nums text-rose-400 self-end mb-0.5" style="font-size: 0.35em">00</span>
              </div>

              <!-- 日期 + 星期 -->
              <div class="mt-3 sm:mt-4 flex items-center gap-2 sm:gap-3 relative z-10">
                <span class="w-4 sm:w-6 h-px bg-gradient-to-r from-transparent via-amber-300/60 to-amber-300/60"></span>
                <span id="clock-date" class="text-xs sm:text-sm md:text-base tracking-[0.15em] text-amber-600/80 font-medium">----年--月--日</span>
                <span class="w-4 sm:w-6 h-px bg-gradient-to-r from-amber-300/60 via-amber-300/60 to-transparent"></span>
              </div>
              <div class="mt-1 relative z-10">
                <span id="clock-weekday" class="bg-gradient-to-r from-amber-600 to-rose-600 bg-clip-text text-transparent font-bold tracking-wider text-sm sm:text-base md:text-lg">---</span>
              </div>

              <!-- 时区标识 -->
              <div class="mt-2 sm:mt-3 flex items-center gap-1.5 text-[10px] sm:text-[11px] text-amber-400/50 tracking-widest relative z-10">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="sm:w-3 sm:h-3"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                北 京 时 间
              </div>
            </div>
          </div>

          <!-- 照片墙 -->
          <div data-nav="photos" class="group relative overflow-hidden rounded-3xl shadow-sm cursor-pointer" style="aspect-ratio: 16/9">
            <div class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" id="photo-bg"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
            <div class="relative z-10 flex h-full flex-col justify-between p-5">
              <h3 class="text-lg font-bold text-white drop-shadow-sm">照片墙</h3>
              <div class="flex items-center justify-between">
                <span id="photo-caption" class="text-sm text-white/80 font-light">-</span>
                <div class="flex gap-1.5" id="photo-dots">
                  {photoEntries.map(() => (
                    <span class="inline-block h-1.5 w-1.5 rounded-full bg-white/50 transition-all"></span>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- 项目 + 杂谈 并排 -->
          <div class="grid gap-4 md:grid-cols-2">
            <div data-nav="projects" class="group relative overflow-hidden rounded-3xl shadow-sm cursor-pointer" style="aspect-ratio: 16/9">
              <div class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" id="project-bg"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
              <div class="relative z-10 flex h-full flex-col justify-between p-5">
                <h3 class="text-lg font-bold text-white drop-shadow-sm">项目</h3>
                <div>
                  <div id="project-caption" class="text-white"></div>
                  <div class="mt-3 flex justify-center gap-1.5" id="project-dots">
                    {projectBgImages.map((_, i) => (
                      <span class={`inline-block h-1.5 ${i === 0 ? 'w-4' : 'w-1.5'} rounded-full ${i === 0 ? 'bg-white' : 'bg-white/50'} transition-all`}></span>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <div data-nav="talks" class="group relative overflow-hidden rounded-3xl shadow-sm cursor-pointer" style="aspect-ratio: 16/9">
              <div class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" id="talk-bg"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
              <div class="relative z-10 flex h-full flex-col justify-between p-5">
                <h3 class="text-lg font-bold text-white drop-shadow-sm">杂谈</h3>
                <div>
                  <div id="talk-caption" class="text-white"></div>
                  <div class="mt-3 flex justify-center gap-1.5" id="talk-dots">
                    {talkBgImages.map((_, i) => (
                      <span class={`inline-block h-1.5 ${i === 0 ? 'w-4' : 'w-1.5'} rounded-full ${i === 0 ? 'bg-white' : 'bg-white/50'} transition-all`}></span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ========== 项目 ========== -->
      <section id="section-projects" class="section-content">
        <div class="pt-8">
          <h2 class="mb-2 text-4xl font-bold">项目</h2>
          <p class="mb-10 text-gray-500">一些正在做和做过的东西。</p>

          <div class="grid gap-6 md:grid-cols-2">
            {projects.map((p, i) => (
              <a href={`/projects/${p.slug}`} class="group relative block overflow-hidden rounded-3xl shadow-sm transition hover:shadow-xl" style={`aspect-ratio: 4/3`}>
                <div class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" style={`background-image:url(${projectBgImages[i]})`}></div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                <div class="relative z-10 flex h-full flex-col justify-end p-6">
                  <div class="mb-2 flex h-10 w-10 items-center justify-center rounded-xl bg-white/20 backdrop-blur-sm text-xl">{p.emoji}</div>
                  <h3 class="text-xl font-bold text-white">{p.title}</h3>
                  <p class="mt-1 text-sm text-white/80">{p.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== 杂谈 ========== -->
      <section id="section-talks" class="section-content">
        <div class="pt-8">
          <h2 class="mb-2 text-4xl font-bold">杂谈</h2>
          <p class="mb-10 text-gray-500">一些想法、笔记与记录。</p>

          <div class="grid gap-6 md:grid-cols-2">
            {talks.map((t, i) => (
              <a href={`/talks/${t.slug}`} class="group relative block overflow-hidden rounded-3xl shadow-sm transition hover:shadow-xl" style={`aspect-ratio: 4/3`}>
                <div class="absolute inset-0 bg-cover bg-center transition duration-500 group-hover:scale-105" style={`background-image:url(${talkBgImages[i]})`}></div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                <div class="relative z-10 flex h-full flex-col justify-end p-6">
                  <div class="mb-2 flex items-center gap-2">
                    <span class="rounded-full bg-white/20 backdrop-blur-sm px-3 py-0.5 text-xs text-white">{t.tag}</span>
                    <span class="text-xs text-white/60">{t.date}</span>
                  </div>
                  <h3 class="text-lg font-bold text-white">{t.title}</h3>
                  <p class="mt-1 text-sm text-white/80 leading-relaxed">{t.content.split('\n')[0]}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== 照片墙 ========== -->
      <section id="section-photos" class="section-content">
        <div class="pt-8">
          <h2 class="mb-2 text-4xl font-bold">照片墙</h2>
          <p class="mb-6 text-gray-500">用镜头记录的瞬间。</p>

          <div class="mb-6 flex flex-wrap gap-2" id="photo-categories">
            {categories.map((cat, i) => (
              <button class={`rounded-full px-4 py-1.5 text-sm font-medium transition cursor-pointer photo-cat-btn ${i === 0 ? 'bg-violet-600 text-white' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}`} data-cat={cat}>{cat}</button>
            ))}
          </div>

          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3" id="photo-grid">
            {photoEntries.map((url, i) => (
              <button class="group relative aspect-square overflow-hidden rounded-3xl shadow-sm cursor-pointer text-left" data-photo-index={i} data-cat={photoCat[i]}>
                <img src={url} alt="" class="h-full w-full object-cover transition duration-500 group-hover:scale-110" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition duration-300 group-hover:opacity-100">
                  <span class="absolute bottom-3 left-3 text-sm text-white/90">{(i + 1).toString().padStart(2, '0')}</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== 动漫 ========== -->
      <section id="section-anime" class="section-content">
        <div class="pt-8">
          <h2 class="mb-2 text-4xl font-bold">动漫</h2>
          <p class="mb-10 text-gray-500">那些打动过我的作品。</p>

          <div class="grid gap-6 md:grid-cols-2">
            {animeList.map((a) => (
              <div class="flex gap-5 rounded-3xl border border-gray-200 bg-stone-50/70 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
                <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-100 to-violet-100 text-3xl">
                  {a.emoji}
                </div>
                <div>
                  <h3 class="mb-1 text-xl font-bold">{a.title}</h3>
                  <p class="text-sm text-gray-400">{a.englishName}</p>
                  <p class="mt-2 leading-relaxed text-gray-600">{a.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== 游戏交流 ========== -->
      <section id="section-gaming" class="section-content">
        <div class="pt-8">
          <h2 class="mb-2 text-4xl font-bold">游戏交流</h2>
          <p class="mb-10 text-gray-500">关于游戏的热爱与讨论。</p>

          <div class="grid gap-6 md:grid-cols-2">
            {gamingList.map((g) => (
              <div class="rounded-3xl border border-gray-200 bg-stone-50/70 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-100 to-violet-100 text-2xl">
                  {g.emoji}
                </div>
                <h3 class="mb-2 text-xl font-bold">{g.title}</h3>
                <p class="leading-relaxed text-gray-600">{g.content}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

    </main>

    <!-- 照片灯箱 -->
    <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
      <button id="lightbox-close" class="absolute top-4 right-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white/70 transition hover:bg-white/20 hover:text-white">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white/70 transition hover:bg-white/20 hover:text-white">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <img id="lightbox-img" class="max-h-[90vh] max-w-[90vw] rounded-2xl object-contain shadow-2xl" />
      <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white/70 transition hover:bg-white/20 hover:text-white">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
      <span id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-white/10 px-4 py-1 text-sm text-white/70"></span>
    </div>

    <template id="playlist-data" set:html={songsJson}></template>
    <template id="photo-urls" set:html={photoUrlsJson}></template>
    <template id="project-bg-data" set:html={projectBgJson}></template>
    <template id="talk-bg-data" set:html={talkBgJson}></template>
    <template id="photo-cat-data" set:html={photoCatJson}></template>
    <template id="categories-data" set:html={categoriesJson}></template>
    <template id="projects-data" set:html={projectsJson}></template>
    <template id="talks-data" set:html={talksJson}></template>
    <script>
      // 导航栏滚动隐藏
      const header = document.querySelector("header");
      let lastScroll = 0;

      window.addEventListener("scroll", () => {
        const currentScroll = window.scrollY;
        if (currentScroll > lastScroll && currentScroll > 80) {
          header.classList.add("-translate-y-full");
        } else {
          header.classList.remove("-translate-y-full");
        }
        lastScroll = currentScroll;
      });

      // 导航切换逻辑
      const navLinks = document.querySelectorAll(".nav-link");
      const sections = document.querySelectorAll(".section-content");

      function switchSection(sectionId) {
        // 切换 section 显隐
        sections.forEach((el) => {
          el.classList.toggle("active", el.id === "section-" + sectionId);
        });

        // 更新导航高亮
        navLinks.forEach((btn) => {
          const isActive = btn.dataset.section === sectionId;
          btn.classList.toggle("text-blue-600", isActive);
          btn.classList.toggle("text-gray-500", !isActive);
        });
      }

      // 支持 URL hash 定位到对应模块
      const hash = location.hash.replace('#section-', '');
      if (hash && ['projects', 'talks', 'photos', 'anime', 'gaming'].includes(hash)) {
        switchSection(hash);
        requestAnimationFrame(function() {
          document.getElementById('section-' + hash)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
      window.addEventListener('hashchange', function() {
        const h = location.hash.replace('#section-', '');
        if (h && ['projects', 'talks', 'photos', 'anime', 'gaming'].includes(h)) {
          switchSection(h);
          requestAnimationFrame(function() {
            document.getElementById('section-' + h)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
      });

      navLinks.forEach((btn) => {
        btn.addEventListener("click", () => {
          switchSection(btn.dataset.section);
        });
      });

      // "查看全部" 导航按钮
      document.querySelectorAll('[data-nav]').forEach(btn => {
        btn.addEventListener('click', () => switchSection(btn.dataset.nav));
      });

      // 个人名片整块点击跳转
      document.querySelector('[data-about-card]')?.addEventListener('click', (e) => {
        if (e.target.closest('button') || e.target.closest('a')) return;
        window.location.href = '/about';
      });

      // ====== 北京时间 ======
      function updateClock() {
        const now = new Date();
        const beijing = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Shanghai' }));
        const h = String(beijing.getHours()).padStart(2, '0');
        const m = String(beijing.getMinutes()).padStart(2, '0');
        const s = String(beijing.getSeconds()).padStart(2, '0');
        const y = beijing.getFullYear();
        const mo = String(beijing.getMonth() + 1).padStart(2, '0');
        const d = String(beijing.getDate()).padStart(2, '0');
        const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
        const wd = weekdays[beijing.getDay()];

        document.getElementById('clock-hour').textContent = h;
        document.getElementById('clock-min').textContent = m;
        document.getElementById('clock-sec').textContent = s;
        document.getElementById('clock-date').textContent = y + '年' + mo + '月' + d + '日';
        document.getElementById('clock-weekday').textContent = wd;
      }
      updateClock();
      setInterval(updateClock, 1000);

      // ====== 背景轮播切换（图片背景 + 文字浮层） ======
      function createBgCarousel(bgId, captionId, dotsId, items, interval = 10000) {
        const bgEl = document.getElementById(bgId);
        const captionEl = document.getElementById(captionId);
        const dots = document.querySelectorAll('#' + dotsId + ' span');
        if (!bgEl || !dots.length) return;
        let index = 0;

        function show(i) {
          index = (i + items.length) % items.length;
          const item = items[index];
          bgEl.style.backgroundImage = 'url(' + item.bg + ')';
          if (captionEl && item.html) {
            captionEl.innerHTML = item.html;
          }
          dots.forEach((dot, di) => {
            dot.className = di === index
              ? 'inline-block h-1.5 w-4 rounded-full bg-white transition-all'
              : 'inline-block h-1.5 w-1.5 rounded-full bg-white/50 transition-all';
          });
        }

        show(0);
        setInterval(() => show(index + 1), interval);
      }

      // 项目轮播
      (function() {
        const projectBgs = JSON.parse(document.getElementById('project-bg-data')?.innerHTML || '[]');
        const projects = JSON.parse(document.getElementById('projects-data')?.innerHTML || '[]');
        if (projectBgs.length > 0 && projects.length > 0) {
          createBgCarousel('project-bg', 'project-caption', 'project-dots', projects.map(function(p, i) {
            return {
              bg: projectBgs[i % projectBgs.length],
              html: '<div class="flex items-center gap-2"><span class="text-xl">' + p.emoji + '</span><div><p class="text-sm font-bold text-white">' + p.title + '</p><p class="text-xs text-white/70">' + p.description + '</p></div></div>'
            };
          }));
        }
      })();

      // 照片轮播
      (function() {
        const photoUrls = JSON.parse(document.getElementById('photo-urls')?.innerHTML || '[]');
        if (photoUrls.length > 0) {
          createBgCarousel('photo-bg', 'photo-caption', 'photo-dots', photoUrls.map((url, i) => ({
            bg: url,
            html: '📷 照片 ' + (i + 1)
          })));
        }
      })();

      // 杂谈轮播
      (function() {
        const talkBgs = JSON.parse(document.getElementById('talk-bg-data')?.innerHTML || '[]');
        const talks = JSON.parse(document.getElementById('talks-data')?.innerHTML || '[]');
        if (talkBgs.length > 0 && talks.length > 0) {
          createBgCarousel('talk-bg', 'talk-caption', 'talk-dots', talks.map(function(t, i) {
            return {
              bg: talkBgs[i % talkBgs.length],
              html: '<span class="rounded-full bg-white/20 backdrop-blur-sm px-2 py-0.5 text-xs text-white">' + t.tag + '</span><p class="mt-1 text-sm font-bold text-white">' + t.title + '</p><p class="text-xs text-white/60">' + t.date + '</p>'
            };
          }));
        }
      })();

      // ====== 照片灯箱 ======
      const photoUrls = JSON.parse(document.getElementById('photo-urls')?.innerHTML || '[]');
      let lightboxIndex = 0;

      function openLightbox(index) {
        lightboxIndex = index;
        const lb = document.getElementById('lightbox');
        const img = document.getElementById('lightbox-img');
        const counter = document.getElementById('lightbox-counter');
        img.src = photoUrls[index];
        counter.textContent = (index + 1) + ' / ' + photoUrls.length;
        lb.classList.remove('hidden');
        lb.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }

      document.querySelectorAll('[data-photo-index]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          openLightbox(parseInt(this.dataset.photoIndex));
        });
      });

      function closeLightbox() {
        const lb = document.getElementById('lightbox');
        lb.classList.add('hidden');
        lb.classList.remove('flex');
        document.body.style.overflow = '';
      }

      function navigateLightbox(dir) {
        lightboxIndex = (lightboxIndex + dir + photoUrls.length) % photoUrls.length;
        const img = document.getElementById('lightbox-img');
        const counter = document.getElementById('lightbox-counter');
        img.src = photoUrls[lightboxIndex];
        counter.textContent = (lightboxIndex + 1) + ' / ' + photoUrls.length;
      }

      document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
      document.getElementById('lightbox-prev').addEventListener('click', function() { navigateLightbox(-1); });
      document.getElementById('lightbox-next').addEventListener('click', function() { navigateLightbox(1); });
      document.getElementById('lightbox').addEventListener('click', function(e) {
        if (e.target === this) closeLightbox();
      });
      document.addEventListener('keydown', function(e) {
        const lb = document.getElementById('lightbox');
        if (lb.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigateLightbox(-1);
        if (e.key === 'ArrowRight') navigateLightbox(1);
      });

      // ====== 照片分类切换 ======
      document.getElementById('photo-categories').addEventListener('click', function(e) {
        const btn = e.target.closest('.photo-cat-btn');
        if (!btn) return;
        this.querySelectorAll('.photo-cat-btn').forEach(function(b) {
          b.className = 'photo-cat-btn rounded-full px-4 py-1.5 text-sm font-medium transition cursor-pointer ' +
            (b === btn ? 'bg-violet-600 text-white' : 'bg-gray-100 text-gray-500 hover:bg-gray-200');
        });
        const cat = btn.dataset.cat;
        document.querySelectorAll('#photo-grid [data-photo-index]').forEach(function(el) {
          el.style.display = cat === '全部' || el.dataset.cat === cat ? '' : 'none';
        });
      });

      // ====== 音乐播放器 ======
      const songs = JSON.parse(document.getElementById('playlist-data')?.innerHTML || '[]');
      if (songs.length > 0) {
        const audio = new Audio();
        let isPlaying = false;
        let currentIndex = -1;

        const disc = document.getElementById('record-disc');
        const albumArt = document.getElementById('album-art');
        const songName = document.getElementById('song-name');
        const artistName = document.getElementById('artist-name');
        const playBtn = document.getElementById('play-btn');
        const playIcon = document.getElementById('play-icon');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const progressFill = document.getElementById('progress-fill');
        const progressBar = document.getElementById('progress-bar');
        const currentTimeEl = document.getElementById('current-time');
        const totalTimeEl = document.getElementById('total-time');

        let discAngle = 0;
        let rotationInterval = null;

        function formatTime(s) {
          const m = Math.floor(s / 60);
          const sec = Math.floor(s % 60);
          return m + ':' + (sec < 10 ? '0' : '') + sec;
        }

        function loadSong(index) {
          const song = songs[index];
          currentIndex = index;
          songName.textContent = song.name;
          artistName.textContent = song.artists;
          albumArt.src = song.picUrl;
          audio.src = 'https://music.163.com/song/media/outer/url?id=' + song.id + '.mp3';
          audio.load();
          totalTimeEl.textContent = formatTime(song.duration / 1000);
          progressFill.style.width = '0%';
          currentTimeEl.textContent = '0:00';

          // Reset rotation
          if (disc) disc.style.transform = 'rotate(0deg)';
          discAngle = 0;
        }

        function play() {
          audio.play().catch(() => {});
          isPlaying = true;
          playIcon.innerHTML = '<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>';
          // Start spinning
          if (rotationInterval) clearInterval(rotationInterval);
          rotationInterval = setInterval(() => {
            discAngle = (discAngle + 1) % 360;
            if (disc) disc.style.transform = 'rotate(' + discAngle + 'deg)';
          }, 50);
        }

        function pause() {
          audio.pause();
          isPlaying = false;
          playIcon.innerHTML = '<path d="M8 5v14l11-7z"/>';
          if (rotationInterval) {
            clearInterval(rotationInterval);
            rotationInterval = null;
          }
        }

        function togglePlay() {
          if (isPlaying) pause();
          else play();
        }

        function randomSong() {
          let newIndex;
          do {
            newIndex = Math.floor(Math.random() * songs.length);
          } while (newIndex === currentIndex && songs.length > 1);
          loadSong(newIndex);
          if (isPlaying) play();
          else {
            // Show song info even when not playing
          }
        }

        // Load a random song on start
        currentIndex = Math.floor(Math.random() * songs.length);
        loadSong(currentIndex);

        // ====== 自动播放音乐（浏览器可能拦截，首次交互时启动） ======
        function startPlayback() {
          play();
        }
        var autoPromise = audio.play();
        if (autoPromise !== undefined) {
          autoPromise.then(startPlayback).catch(function() {
            var firstTap = function() {
              startPlayback();
              document.removeEventListener('click', firstTap);
              document.removeEventListener('touchstart', firstTap);
            };
            document.addEventListener('click', firstTap);
            document.addEventListener('touchstart', firstTap);
          });
        }

        // Event listeners
        playBtn.addEventListener('click', togglePlay);

        nextBtn.addEventListener('click', () => {
          randomSong();
          if (!isPlaying) play();
        });

        prevBtn.addEventListener('click', () => {
          randomSong();
          if (!isPlaying) play();
        });

        audio.addEventListener('timeupdate', () => {
          if (audio.duration) {
            const pct = (audio.currentTime / audio.duration) * 100;
            progressFill.style.width = pct + '%';
            currentTimeEl.textContent = formatTime(audio.currentTime);
          }
        });

        audio.addEventListener('ended', () => {
          randomSong();
          play();
        });

        progressBar.addEventListener('click', (e) => {
          const rect = progressBar.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          audio.currentTime = pct * audio.duration;
        });

        // Handle loading errors - skip to next
        audio.addEventListener('error', () => {
          setTimeout(randomSong, 1000);
        });

        // ====== 拖拽移动 ======
        const player = document.getElementById('music-player');
        let isDragging = false;
        let hasMoved = false;
        let startX, startY, origLeft, origTop;

        player.addEventListener('pointerdown', (e) => {
          if (e.target.closest('button')) return;
          const rect = player.getBoundingClientRect();
          player.style.left = rect.left + 'px';
          player.style.top = rect.top + 'px';
          player.style.right = 'auto';
          startX = e.clientX;
          startY = e.clientY;
          origLeft = rect.left;
          origTop = rect.top;
          isDragging = true;
          hasMoved = false;
          player.setPointerCapture(e.pointerId);
        });

        player.addEventListener('pointermove', (e) => {
          if (!isDragging) return;
          const dx = e.clientX - startX;
          const dy = e.clientY - startY;
          if (Math.abs(dx) > 3 || Math.abs(dy) > 3) hasMoved = true;
          player.style.left = (origLeft + dx) + 'px';
          player.style.top = (origTop + dy) + 'px';
        });

        player.addEventListener('pointerup', () => {
          isDragging = false;
        });

        // ====== 双击展开/折叠 ======
        player.addEventListener('dblclick', (e) => {
          if (e.target.closest('button')) return;
          const expanded = player.classList.toggle('expanded');
          if (expanded) {
            player.style.width = '20rem';
            artistName.classList.remove('sr-only');
          } else {
            player.style.width = '';
            artistName.classList.add('sr-only');
          }
        });
      }
    </script>

    <script>
      // ====== 视觉特效引擎 ======
      // 包含：星野 · 流星 · 萤火虫 · 彩虹雨 · 环境光晕 · 浮游光点
      (function() {
        var cvs = document.getElementById('effects-canvas');
        if (!cvs) return;
        var ctx = cvs.getContext('2d');
        var W, H;

        function fit() {
          W = cvs.width = window.innerWidth;
          H = cvs.height = window.innerHeight;
        }
        fit();
        window.addEventListener('resize', fit);

        // ========== 1. 环境光晕 (大尺寸彩色柔光球，缓慢漂移) ==========
        var orbs = [];
        var orbColors = [
          { h: 210, s: 60, l: 75 },  // 淡蓝
          { h: 270, s: 50, l: 75 },  // 淡紫
          { h: 180, s: 50, l: 75 },  // 淡青
          { h: 330, s: 40, l: 80 },  // 淡粉
          { h: 45,  s: 50, l: 80 },  // 淡金
        ];
        for (var o = 0; o < 8; o++) {
          var c = orbColors[o % orbColors.length];
          orbs.push({
            x: Math.random() * W,
            y: Math.random() * H,
            r: 100 + Math.random() * 150,
            vx: (Math.random() - 0.5) * 0.1,
            vy: (Math.random() - 0.5) * 0.1,
            alpha: 0.06 + Math.random() * 0.06,
            hue: c.h,
            sat: c.s,
            lig: c.l,
          });
        }

        // ========== 2. 星野 ==========
        var stars = [];
        for (var s = 0; s < 150; s++) {
          var isBright = Math.random() > 0.85;
          stars.push({
            x: Math.random() * W,
            y: Math.random() * H * 0.75,
            r: isBright ? 1.5 + Math.random() * 2 : 0.5 + Math.random() * 1,
            speed: Math.random() * 0.02 + 0.005,
            phase: Math.random() * Math.PI * 2,
            bright: isBright,
          });
        }

        // ========== 3. 流星 ==========
        var comets = [];
        var cometTimer = Math.random() * 120 + 80;

        // ========== 4. 萤火虫 ==========
        var bugs = [];
        for (var b = 0; b < 30; b++) {
          bugs.push({
            x: Math.random() * W,
            y: Math.random() * H,
            r: 1.5 + Math.random() * 2,
            speed: Math.random() * 0.015 + 0.006,
            phase: Math.random() * Math.PI * 2,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3,
            glowSize: 35 + Math.random() * 25,
            hue: 45 + Math.random() * 20,  // 暖黄 ~ 金黄
          });
        }

        // ========== 5. 彩虹雨 ==========
        var hues = [0, 25, 50, 120, 195, 250, 310];
        var rain = [];
        for (var r = 0; r < 50; r++) {
          rain.push({
            x: Math.random() * W,
            y: -Math.random() * H,
            len: 8 + Math.random() * 18,
            speed: 1.5 + Math.random() * 3,
            alpha: 0.15 + Math.random() * 0.25,
            hue: hues[Math.floor(Math.random() * hues.length)],
            sway: Math.random() * 200,
          });
        }

        // ========== 6. 浮游光点 ==========
        var sparkles = [];
        for (var p = 0; p < 40; p++) {
          sparkles.push({
            x: Math.random() * W,
            y: Math.random() * H,
            r: 0.5 + Math.random() * 1.2,
            speed: 0.2 + Math.random() * 0.5,
            drift: (Math.random() - 0.5) * 0.2,
            alpha: 0.2 + Math.random() * 0.4,
            phase: Math.random() * Math.PI * 2,
          });
        }

        // ========== 7. 点击水波 ==========
        var ripples = [];
        cvs.addEventListener('click', function(e) {
          var rect = cvs.getBoundingClientRect();
          var cx = e.clientX - rect.left;
          var cy = e.clientY - rect.top;
          // 每次点击生成 3 个同心环
          for (var w = 0; w < 3; w++) {
            ripples.push({
              x: cx,
              y: cy,
              r: 5 + w * 8,         // 起始半径略错开
              maxR: 60 + Math.random() * 40 + w * 20,
              speed: 2 + Math.random() * 1.5,
              alpha: 0.6 - w * 0.12,
              hue: 210 + Math.random() * 60,  // 蓝~紫色系
              width: 2.5 - w * 0.4,
            });
          }
        });
        // 触摸支持
        cvs.addEventListener('touchstart', function(e) {
          var touch = e.touches[0];
          if (!touch) return;
          var rect = cvs.getBoundingClientRect();
          var cx = touch.clientX - rect.left;
          var cy = touch.clientY - rect.top;
          for (var w = 0; w < 3; w++) {
            ripples.push({
              x: cx, y: cy,
              r: 5 + w * 8,
              maxR: 60 + Math.random() * 40 + w * 20,
              speed: 2 + Math.random() * 1.5,
              alpha: 0.6 - w * 0.12,
              hue: 210 + Math.random() * 60,
              width: 2.5 - w * 0.4,
            });
          }
        }, { passive: true });

        var frame = 0;
        var hidden = false;
        document.addEventListener('visibilitychange', function() { hidden = document.hidden; });

        function loop() {
          if (hidden) { requestAnimationFrame(loop); return; }
          ctx.clearRect(0, 0, W, H);
          frame++;

          // ------ 1. 环境光晕 (先画，作为底层氛围) ------
          for (var oI = 0; oI < orbs.length; oI++) {
            var o = orbs[oI];
            o.x += o.vx;
            o.y += o.vy;
            if (o.x < -o.r) o.x = W + o.r;
            if (o.x > W + o.r) o.x = -o.r;
            if (o.y < -o.r) o.y = H + o.r;
            if (o.y > H + o.r) o.y = -o.r;

            var grad = ctx.createRadialGradient(o.x, o.y, 0, o.x, o.y, o.r);
            grad.addColorStop(0, 'hsla(' + o.hue + ',' + o.sat + '%,' + o.lig + '%,' + o.alpha + ')');
            grad.addColorStop(1, 'hsla(' + o.hue + ',' + o.sat + '%,' + o.lig + '%,0)');
            ctx.fillStyle = grad;
            ctx.fillRect(o.x - o.r, o.y - o.r, o.r * 2, o.r * 2);
          }

          // ------ 2. 星星 ------
          for (var sI = 0; sI < stars.length; sI++) {
            var st = stars[sI];
            var a = 0.4 + 0.6 * (0.5 + 0.5 * Math.sin(frame * st.speed + st.phase));
            if (st.bright) {
              a += 0.2; // 亮星更亮
              // 亮星光晕
              var gSt = ctx.createRadialGradient(st.x, st.y, 0, st.x, st.y, 8);
              gSt.addColorStop(0, 'rgba(200,220,255,' + (a * 0.12) + ')');
              gSt.addColorStop(1, 'rgba(200,220,255,0)');
              ctx.fillStyle = gSt;
              ctx.fillRect(st.x - 8, st.y - 8, 16, 16);
            }
            ctx.beginPath();
            ctx.arc(st.x, st.y, st.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(255,255,255,' + a + ')';
            ctx.fill();
          }

          // ------ 3. 流星 ------
          cometTimer--;
          if (cometTimer <= 0) {
            if (comets.length < 2) {
              var startX = Math.random() * W * 0.7;
              var startY = Math.random() * H * 0.25;
              var angle = Math.PI / 3.5 + (Math.random() - 0.5) * 0.35;
              var len = 80 + Math.random() * 80;
              var speed = 10 + Math.random() * 8;
              comets.push({
                x: startX,
                y: startY,
                len: len,
                speed: speed,
                angle: angle,
                life: 1,
                trail: [],  // 拖尾历史
              });
            }
            cometTimer = 150 + Math.random() * 200;
          }

          for (var cI = comets.length - 1; cI >= 0; cI--) {
            var c = comets[cI];
            c.x += Math.cos(c.angle) * c.speed;
            c.y += Math.sin(c.angle) * c.speed;
            c.life -= 0.015;
            c.trail.push({ x: c.x, y: c.y, life: 1 });

            // 限制 trail 长度
            if (c.trail.length > 15) c.trail.shift();

            if (c.life <= 0 || c.x > W + 50 || c.y > H + 50) {
              comets.splice(cI, 1);
              continue;
            }

            var a = c.life * 0.7;

            // 拖尾渐变
            for (var tI = 0; tI < c.trail.length; tI++) {
              var t = c.trail[tI];
              t.life -= 0.06;
              if (t.life <= 0) continue;
              ctx.beginPath();
              ctx.arc(t.x, t.y, 1.5 * t.life, 0, Math.PI * 2);
              ctx.fillStyle = 'rgba(180,210,255,' + (a * t.life * 0.3) + ')';
              ctx.fill();
            }

            // 流星主体 (亮白色渐变)
            var gradC = ctx.createLinearGradient(c.x, c.y, c.x - Math.cos(c.angle) * c.len, c.y - Math.sin(c.angle) * c.len);
            gradC.addColorStop(0, 'rgba(255,255,255,' + a + ')');
            gradC.addColorStop(0.3, 'rgba(200,220,255,' + (a * 0.6) + ')');
            gradC.addColorStop(1, 'rgba(200,220,255,0)');
            ctx.beginPath();
            ctx.moveTo(c.x, c.y);
            ctx.lineTo(c.x - Math.cos(c.angle) * c.len, c.y - Math.sin(c.angle) * c.len);
            ctx.strokeStyle = gradC;
            ctx.lineWidth = 2.5;
            ctx.stroke();

            // 流星头部光晕
            var gCom = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, 12);
            gCom.addColorStop(0, 'rgba(255,255,255,' + (a * 0.5) + ')');
            gCom.addColorStop(1, 'rgba(255,255,255,0)');
            ctx.fillStyle = gCom;
            ctx.fillRect(c.x - 12, c.y - 12, 24, 24);

            // 头部亮点
            ctx.beginPath();
            ctx.arc(c.x, c.y, 3, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(255,255,255,' + (a * 0.9) + ')';
            ctx.fill();
          }

          // ------ 4. 萤火虫 ------
          for (var bI = 0; bI < bugs.length; bI++) {
            var bug = bugs[bI];
            bug.vx += (Math.random() - 0.5) * 0.06;
            bug.vy += (Math.random() - 0.5) * 0.06;
            bug.vx *= 0.94;
            bug.vy *= 0.94;
            bug.x += bug.vx;
            bug.y += bug.vy;
            if (bug.x < 0) bug.x = W;
            if (bug.x > W) bug.x = 0;
            if (bug.y < 0) bug.y = H;
            if (bug.y > H) bug.y = 0;

            var ba = 0.2 + 0.8 * (0.5 + 0.5 * Math.sin(frame * bug.speed + bug.phase));

            // 大范围暖光晕 (加强)
            var gBug = ctx.createRadialGradient(bug.x, bug.y, 0, bug.x, bug.y, bug.glowSize);
            gBug.addColorStop(0, 'hsla(' + bug.hue + ',85%,78%,' + (ba * 0.55) + ')');
            gBug.addColorStop(0.4, 'hsla(' + bug.hue + ',85%,78%,' + (ba * 0.25) + ')');
            gBug.addColorStop(1, 'hsla(' + bug.hue + ',85%,78%,0)');
            ctx.fillStyle = gBug;
            ctx.fillRect(bug.x - bug.glowSize, bug.y - bug.glowSize, bug.glowSize * 2, bug.glowSize * 2);

            // 内层光晕 (加强)
            var gBug2 = ctx.createRadialGradient(bug.x, bug.y, 0, bug.x, bug.y, bug.glowSize * 0.35);
            gBug2.addColorStop(0, 'hsla(55,100%,92%,' + (ba * 0.8) + ')');
            gBug2.addColorStop(1, 'hsla(55,100%,92%,0)');
            ctx.fillStyle = gBug2;
            ctx.fillRect(bug.x - bug.glowSize * 0.35, bug.y - bug.glowSize * 0.35, bug.glowSize * 0.7, bug.glowSize * 0.7);

            // 虫体 (更亮)
            ctx.beginPath();
            ctx.arc(bug.x, bug.y, bug.r, 0, Math.PI * 2);
            ctx.fillStyle = 'hsla(55,100%,98%,' + (ba * 0.9) + ')';
            ctx.fill();

            // 虫体核心高光
            ctx.beginPath();
            ctx.arc(bug.x - bug.r * 0.2, bug.y - bug.r * 0.2, bug.r * 0.35, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(255,255,255,' + (ba * 0.6) + ')';
            ctx.fill();
          }

          // ------ 5. 彩虹雨 ------
          for (var rI = 0; rI < rain.length; rI++) {
            var rd = rain[rI];
            rd.y += rd.speed;
            rd.x += Math.sin(frame * 0.03 + rd.sway) * 0.2;
            if (rd.y > H + 20) {
              rd.y = -rd.len - 10;
              rd.x = Math.random() * W;
            }

            ctx.beginPath();
            ctx.moveTo(rd.x, rd.y);
            ctx.lineTo(rd.x + Math.sin(frame * 0.02 + rd.sway) * 0.4, rd.y + rd.len);
            ctx.strokeStyle = 'hsla(' + rd.hue + ',75%,72%,' + rd.alpha + ')';
            ctx.lineWidth = 1.8;
            ctx.lineCap = 'round';
            ctx.stroke();

            // 雨滴尾部发光
            var gRain = ctx.createRadialGradient(rd.x, rd.y + rd.len, 0, rd.x, rd.y + rd.len, 3);
            gRain.addColorStop(0, 'hsla(' + rd.hue + ',75%,72%,' + (rd.alpha * 0.3) + ')');
            gRain.addColorStop(1, 'hsla(' + rd.hue + ',75%,72%,0)');
            ctx.fillStyle = gRain;
            ctx.fillRect(rd.x - 3, rd.y + rd.len - 3, 6, 6);
          }

          // ------ 6. 浮游光点 ------
          for (var pI = 0; pI < sparkles.length; pI++) {
            var sp = sparkles[pI];
            sp.y -= sp.speed;
            sp.x += sp.drift + Math.sin(frame * 0.01 + sp.phase) * 0.1;
            if (sp.y < -10) {
              sp.y = H + 10;
              sp.x = Math.random() * W;
            }
            if (sp.x < -10) sp.x = W + 10;
            if (sp.x > W + 10) sp.x = -10;

            var spa = sp.alpha * (0.6 + 0.4 * Math.sin(frame * 0.02 + sp.phase));
            ctx.beginPath();
            ctx.arc(sp.x, sp.y, sp.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(255,255,255,' + spa + ')';
            ctx.fill();
          }

          // ------ 7. 水波涟漪 ------
          for (var wI = ripples.length - 1; wI >= 0; wI--) {
            var wv = ripples[wI];
            wv.r += wv.speed;
            wv.alpha *= 0.985;
            if (wv.r > wv.maxR || wv.alpha < 0.01) { ripples.splice(wI, 1); continue; }

            // 外发光
            var gWv = ctx.createRadialGradient(wv.x, wv.y, wv.r * 0.7, wv.x, wv.y, wv.r);
            gWv.addColorStop(0, 'hsla(' + wv.hue + ',70%,75%,0)');
            gWv.addColorStop(0.5, 'hsla(' + wv.hue + ',70%,75%,' + (wv.alpha * 0.15) + ')');
            gWv.addColorStop(1, 'hsla(' + wv.hue + ',70%,75%,0)');
            ctx.fillStyle = gWv;
            ctx.fillRect(wv.x - wv.r, wv.y - wv.r, wv.r * 2, wv.r * 2);

            // 波纹圆圈
            ctx.beginPath();
            ctx.arc(wv.x, wv.y, wv.r, 0, Math.PI * 2);
            ctx.strokeStyle = 'hsla(' + wv.hue + ',65%,80%,' + wv.alpha + ')';
            ctx.lineWidth = wv.width;
            ctx.stroke();

            // 内圈 (更亮)
            ctx.beginPath();
            ctx.arc(wv.x, wv.y, wv.r * 0.7, 0, Math.PI * 2);
            ctx.strokeStyle = 'hsla(210,80%,90%,' + (wv.alpha * 0.4) + ')';
            ctx.lineWidth = wv.width * 0.5;
            ctx.stroke();
          }

          requestAnimationFrame(loop);
        }
        loop();
      })();
    </script>

  </body>
