---
import "../styles/global.css";

import bgImage from "../assets/bg.png";
import headImage from "../assets/head.jpg";
import playlistData from "../music/playlist-data.json";
import projects from "../data/projects.json";
import talks from "../data/talks.json";
import animeList from "../data/anime.json";
import gamingList from "../data/gaming.json";
import photoCategories from "../data/photo-categories.json";

const songs = playlistData;
const songsJson = JSON.stringify(songs);

// 项目/杂谈配图：从所有照片中查找
const allPhotoModules = import.meta.glob(['../photos/*.{jpg,png,jpeg,webp}', '../photos/精选/*.{jpg,png,jpeg,webp}'], { eager: true, import: 'default' });
const allPhotoEntries = Object.entries(allPhotoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.src);

// 照片墙：只展示精选文件夹的图片
const photoWallModules = import.meta.glob('../photos/精选/*.{jpg,png,jpeg,webp}', { eager: true, import: 'default' });
const photoWallEntries = Object.entries(photoWallModules)
  .sort(([a], [b]) => a.localeCompare(b));
const photoWallFilenames = photoWallEntries.map(([path]) => path.split('/').pop());
const photoEntries = photoWallEntries.map(([, mod]) => mod.src);
const photoCount = photoEntries.length;
const photoUrlsJson = JSON.stringify(photoEntries);
const photoCat = photoWallFilenames.map((f) => photoCategories.photos[f] || "日常");
const categories = ["全部"].concat(photoCategories.categories);
const categoriesJson = JSON.stringify(categories);
const photoCatJson = JSON.stringify(photoCat);
const projectCount = projects.length;
const talkCount = talks.length;

// 构建文件名 → URL 映射（用于项目/杂谈配图查找）
const photoMap = {};
Object.entries(allPhotoModules).forEach(([path, mod]) => {
  photoMap[path.split('/').pop()] = mod.src;
});
const fallbackBg = allPhotoEntries[0];

// 取 images 数组第一张（兼容旧 image 字段）
function firstImg(item) {
  const list = item.images || (item.image ? [item.image] : []);
  return photoMap[list[0]] || fallbackBg;
}
const projectBgImages = projects.map(firstImg);
const talkBgImages = talks.map(firstImg);
const [projBg1, projBg2, projBg3, projBg4, projBg5] = projectBgImages;
const [talkBg1, talkBg2, talkBg3, talkBg4] = talkBgImages;
const projectBgJson = JSON.stringify(projectBgImages);
const talkBgJson = JSON.stringify(talkBgImages);
const projectSlugsJson = JSON.stringify(projects.map(p => p.slug));
const projectsJson = JSON.stringify(projects);
const talksJson = JSON.stringify(talks);
---

<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>雾籽米的 Evergarden</title>
  </head>

  <body class="min-h-screen overflow-x-hidden">
    <!-- 背景图 -->
    <div class="fixed inset-0 -z-20">
      <img src={bgImage.src} alt="" class="h-full w-full object-cover object-[center_25%]" />
    </div>

    <!-- 渐变遮罩 — 从上到下逐渐变白，让背景图在 Hero 区更通透 -->
    <div class="fixed inset-0 -z-10 bg-gradient-to-b from-white/10 via-white/25 to-white/50"></div>

    <!-- 导航栏 -->
    <header
      class="fixed top-0 left-0 right-0 z-50 border-b border-gray-200/50 bg-stone-50/70 transition-transform duration-500 ease-in-out"
    >
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a
          href="/"
          class="bg-gradient-to-r from-blue-500 via-violet-500 to-blue-400 bg-clip-text text-xl font-bold text-transparent"
        >
          雾籽米的 Evergarden
        </a>

        <ul class="flex items-center gap-8 text-sm font-medium text-gray-500">
          <li>
            <button data-section="home" class="nav-link text-blue-600 transition hover:text-blue-800">首页</button>
          </li>
          <li>
            <button data-section="projects" class="nav-link transition hover:text-blue-600">项目</button>
          </li>
          <li>
            <button data-section="talks" class="nav-link transition hover:text-blue-600">杂谈</button>
          </li>
          <li>
            <button data-section="photos" class="nav-link transition hover:text-blue-600">照片墙</button>
          </li>
          <li>
            <button data-section="anime" class="nav-link transition hover:text-blue-600">动漫</button>
          </li>
          <li>
            <button data-section="gaming" class="nav-link transition hover:text-blue-600">游戏交流</button>
          </li>
        </ul>
      </nav>
    </header>

    <!-- 浮动音乐播放器（响应式） -->
    <div id="music-player" class="fixed z-40 w-28 sm:w-32 md:w-36 rounded-2xl border border-gray-200/30 bg-white/10 p-2 sm:p-3 shadow-sm backdrop-blur-sm hover:bg-white/20 cursor-grab" style="top:80px;right:16px">
      <div class="flex flex-col items-center gap-1 sm:gap-1.5">
        <!-- 唱片 -->
        <div class="relative h-10 w-10 sm:h-12 sm:w-12 shrink-0" id="disc-container">
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-gray-300 to-gray-100 shadow"></div>
          <div class="absolute inset-0.5 rounded-full bg-gradient-to-br from-gray-900 via-gray-800 to-gray-700" id="record-disc">
            <div class="absolute inset-1.5 rounded-full overflow-hidden ring-1 ring-black/10">
              <img id="album-art" src={songs[0].picUrl} alt="cover" class="h-full w-full object-cover" />
            </div>
            <div class="absolute inset-[30%] rounded-full bg-gradient-to-br from-gray-200 to-white shadow-inner"></div>
            <div class="absolute inset-[38%] rounded-full bg-white/90 shadow"></div>
          </div>
        </div>
        <!-- 歌曲名 -->
        <p id="song-name" class="w-full truncate text-center text-[9px] sm:text-[10px] md:text-xs font-medium text-gray-600 leading-tight">{songs[0].name}</p>
        <p id="artist-name" class="sr-only">{songs[0].artists}</p>
        <!-- 进度条 -->
        <div class="flex w-full items-center gap-1">
          <span id="current-time" class="text-[6px] sm:text-[7px] text-gray-400/70 tabular-nums">0:00</span>
          <div class="relative flex-1 h-[3px] sm:h-1 cursor-pointer rounded-full bg-gray-200/40" id="progress-bar">
            <div class="h-full rounded-full bg-gradient-to-r from-blue-500 to-violet-500" id="progress-fill" style="width:0%"></div>
          </div>
          <span id="total-time" class="text-[6px] sm:text-[7px] text-gray-400/70 tabular-nums">0:00</span>
        </div>
        <!-- 控制按钮 -->
        <div class="flex items-center justify-center gap-1.5 sm:gap-2">
          <button id="prev-btn" class="ctrl-btn flex h-4 w-4 sm:h-5 sm:w-5 items-center justify-center rounded-full text-gray-400/60 transition hover:scale-110 hover:text-gray-600">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor" class="sm:w-[10px] sm:h-[10px]"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
          </button>
          <button id="play-btn" class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-gradient-to-r from-blue-500/80 to-violet-500/80 text-white shadow transition hover:scale-105 active:scale-95">
            <svg id="play-icon" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" class="sm:w-[12px] sm:h-[12px]"><path d="M8 5v14l11-7z"/></svg>
          </button>
          <button id="next-btn" class="ctrl-btn flex h-4 w-4 sm:h-5 sm:w-5 items-center justify-center rounded-full text-gray-400/60 transition hover:scale-110 hover:text-gray-600">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor" class="sm:w-[10px] sm:h-[10px]"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- 主区域：各界面 -->
    <!-- 视觉特效 Canvas -->
    <canvas id="effects-canvas" class="fixed inset-0 z-0 pointer-events-none"></canvas>

    <main class="mx-auto max-w-6xl px-6 pt-20 pb-20 relative z-[1]">

      <!-- ========== 首页 ========== -->
      <section id="section-home" class="section-content active">
        <!-- Hero 区 — 紧凑版 -->
        <div class="relative flex min-h-[40vh] flex-col items-center justify-start overflow-hidden px-6 pt-0 pb-4">
          <div class="absolute top-[-120px] left-1/2 -z-10 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-blue-200/40 blur-[120px]">
          </div>

          <div class="max-w-3xl text-center">
            <p class="mb-4 text-xs tracking-[0.3em] text-gray-500 uppercase">
              Independent Developer · AI · Game Design
            </p>

            <h1 class="mx-auto max-w-xl flex flex-col items-center gap-2 text-center font-bold leading-snug">
              <span class="bg-gradient-to-r from-blue-500 via-violet-500 to-blue-400 bg-clip-text text-3xl text-transparent md:text-5xl">
                花无凋零之时
              </span>
              <span class="bg-gradient-to-r from-blue-500 via-violet-500 to-blue-400 bg-clip-text text-3xl text-transparent md:text-5xl">
                意无传达之日
              </span>
              <span class="bg-gradient-to-r from-blue-500 via-violet-500 to-blue-400 bg-clip-text text-3xl text-transparent md:text-5xl">
                爱情亘古不变
              </span>
              <span class="bg-gradient-to-r from-blue-500 via-violet-500 to-blue-400 bg-clip-text text-3xl text-transparent md:text-5xl">
                紫罗兰永世长存
              </span>
            </h1>

            <p class="mx-auto mb-8 max-w-xl text-base leading-7 text-gray-500 md:text-lg">
              Creating calm, emotional and immersive experiences through AI,
              interaction design and indie game development.
            </p>
          </div>
        </div>

        <!-- 内容模块区 -->
        <div class="space-y-8 pb-16">

          <!-- 关于我 + 时钟 并排 -->
          <div class="grid gap-4 md:grid-cols-3">
            <div data-about-card class="md:col-span-2 rounded-3xl border border-gray-200 bg-stone-50/70 p-6 shadow-sm md:p-8 cursor-pointer transition hover:shadow-md">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
                <img src={headImage.src} alt="陈懿航" class="h-20 w-20 shrink-0 rounded-2xl object-cover" />
                <div class="min-w-0 flex-1">
                  <h3 class="text-2xl font-bold text-gray-800">陈懿航</h3>
                  <p class="text-sm text-gray-400">哈工大（深圳）· 计算机 · 游戏开发</p>
                  <p class="mt-2 leading-relaxed text-gray-600">
                    愿你前行的道路有群星闪耀。愿你留下的足迹有百花绽放。你即是上帝的馈赠，世界因你而瑰丽。
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <span class="rounded-full bg-blue-100 px-3 py-1 text-xs text-blue-600">AI</span>
                    <span class="rounded-full bg-violet-100 px-3 py-1 text-xs text-violet-600">Game Dev</span>
                    <span class="rounded-full bg-sky-100 px-3 py-1 text-xs text-sky-600">UI Design</span>
                  </div>

                  <!-- 统计 -->
                  <div class="mt-4 flex gap-4 border-t border-gray-200/60 pt-4">
                    <button data-nav="talks" class="group cursor-pointer text-left">
                      <span class="text-lg font-bold text-gray-800 group-hover:text-blue-600 transition">{talkCount}</span>
                      <span class="ml-1 text-xs text-gray-400 group-hover:text-blue-500 transition">文章</span>
                    </button>
                    <button data-nav="projects" class="group cursor-pointer text-left">
                      <span class="text-lg font-bold text-gray-800 group-hover:text-blue-600 transition">{projectCount}</span>
                      <span class="ml-1 text-xs text-gray-400 group-hover:text-blue-500 transition">项目</span>
                    </button>
                    <button data-nav="photos" class="group cursor-pointer text-left">
                      <span class="text-lg font-bold text-gray-800 group-hover:text-blue-600 transition">{photoCount}</span>
                      <span class="ml-1 text-xs text-gray-400 group-hover:text-blue-500 transition">相片</span>
                    </button>
                  </div>

                  <!-- 社交 -->
                  <div class="mt-3 flex items-center gap-2.5">
                    <a href="https://github.com/mortis-sys" target="_blank" class="flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition hover:bg-gray-200/60 hover:text-gray-700" title="GitHub">
                      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    </a>
                    <a href="https://space.bilibili.com" target="_blank" class="flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition hover:bg-pink-100/60 hover:text-pink-500" title="B站">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 01-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.267.573-.4.92-.4.347 0 .653.133.92.4L9.653 4.28c.142.124.213.284.213.48 0 .196-.071.356-.213.48l-.56.56h5.814l-.56-.56a.654.654 0 01-.213-.48c0-.196.071-.356.213-.48l1.226-1.226c.267-.267.573-.4.92-.4.347 0 .653.133.92.4.267.267.4.573.4.92 0 .347-.133.653-.4.92l-1.2 1.2zm-9.546 2.4H5.333c-.89.018-1.64.338-2.247.96-.606.622-.924 1.36-.946 2.213v7.36c.022.853.34 1.591.946 2.213.607.622 1.356.942 2.247.96h13.334c.89-.018 1.64-.338 2.247-.96.606-.622.924-1.36.946-2.213v-7.36c-.022-.853-.34-1.591-.946-2.213-.607-.622-1.356-.942-2.247-.96h-2.933l.56.56c.142.124.213.284.213.48 0 .196-.071.356-.213.48l-1.226 1.226c-.267.267-.573.4-.92.4-.347 0-.653-.133-.92-.4L11.44 7.813a.654.654 0 01-.213-.48c0-.196.071-.356.213-.48l.56-.56h-1.813l.56.56c.142.124.213.284.213.48 0 .196-.071.356-.213.48l-1.226 1.226c-.267.267-.573.4-.92.4-.347 0-.653-.133-.92-.4L6.454 7.813a.654.654 0 01-.213-.48c0-.196.071-.356.213-.48l.56-.56h-.747zm2.08 4.853c.124-.124.275-.186.453-.186.178 0 .329.062.453.186l1.067 1.067 1.067-1.067c.124-.124.275-.186.453-.186.178 0 .329.062.453.186.124.124.186.275.186.453 0 .178-.062.329-.186.453l-1.067 1.067 1.067 1.067c.124.124.186.275.186.453 0 .178-.062.329-.186.453-.124.124-.275.186-.453.186-.178 0-.329-.062-.453-.186L12 13.546l-1.067 1.067c-.124.124-.275.186-.453.186-.178 0-.329-.062-.453-.186-.124-.124-.186-.275-.186-.453 0-.178.062-.329.186-.453l1.067-1.067-1.067-1.067c-.124-.124-.186-.275-.186-.453 0-.178.062-.329.186-.453zm5.333 3.734c.124-.124.275-.186.453-.186h2.134c.178 0 .329.062.453.186.124.124.186.275.18